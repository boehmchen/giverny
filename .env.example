# Copy to .env and fill in.

# Cloudflare Tunnel token (Zero Trust → Networks → Tunnels → your tunnel).
CLOUDFLARE_TUNNEL_TOKEN=

# Basic auth for protected projects. All projects are protected by default;
# toggle per-project from the dashboard. Use `./set-password` to set these.
GIVERNY_BASIC_AUTH_USER=admin
GIVERNY_BASIC_AUTH_HASH=

# GitHub PAT (fine-grained, Contents: read) used to clone/pull private repos.
GITHUB_TOKEN=

# Shared secret for GitHub webhooks. Paste the same value into the webhook
# config on every repo you link. Any random high-entropy string works:
#   openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# Shared secret between the daemon API and the dashboard. Generate with:
#   openssl rand -hex 32
GIVERNY_API_TOKEN=
