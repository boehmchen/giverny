#!/usr/bin/env python3
"""Update the shared basic-auth password for protected projects."""
from __future__ import annotations

import getpass
import re
import subprocess
import sys
from pathlib import Path

ENV = Path(__file__).parent / ".env"


def main() -> int:
    pw = sys.argv[1] if len(sys.argv) > 1 else getpass.getpass("new password: ")
    if not pw:
        print("empty password", file=sys.stderr)
        return 1

    hashed = subprocess.run(
        ["docker", "run", "--rm", "caddy:2", "caddy", "hash-password", "--plaintext", pw],
        check=True, capture_output=True, text=True,
    ).stdout.strip()

    # Escape $ so docker compose doesn't try to interpolate the hash as a var.
    escaped = hashed.replace("$", "$$")
    lines = ENV.read_text().splitlines() if ENV.exists() else []
    new = f"GIVERNY_BASIC_AUTH_HASH={escaped}"
    replaced = False
    for i, line in enumerate(lines):
        if re.match(r"\s*GIVERNY_BASIC_AUTH_HASH\s*=", line):
            lines[i] = new
            replaced = True
            break
    if not replaced:
        lines.append(new)
    ENV.write_text("\n".join(lines) + "\n")
    print(f"updated {ENV}")

    subprocess.run(["docker", "compose", "up", "-d", "caddy"], check=True)
    return 0


if __name__ == "__main__":
    sys.exit(main())
